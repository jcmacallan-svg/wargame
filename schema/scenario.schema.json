{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OWGE Scenario",
  "type": "object",
  "required": [
    "name",
    "level",
    "conflict_mode",
    "domains",
    "overview",
    "initial_blue_situation",
    "turns",
    "red_commander_profile"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "strategic",
        "operational",
        "tactical"
      ]
    },
    "conflict_mode": {
      "type": "string",
      "enum": [
        "hybrid",
        "peer",
        "grey_zone",
        "coin"
      ]
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "land",
          "air",
          "maritime",
          "cyber",
          "space",
          "information",
          "logistics"
        ]
      },
      "minItems": 1
    },
    "overview": {
      "type": "string"
    },
    "initial_blue_situation": {
      "type": "string"
    },
    "turns": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "turn": {
      "type": "integer",
      "minimum": 1
    },
    "escalation_stage": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "red_commander_profile": {
      "type": "string",
      "enum": [
        "grey_zone_opportunist",
        "peer_competitor",
        "insurgent_network",
        "regional_coercer"
      ]
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "seed_events": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_situation": {
      "type": "string"
    }
  }
}