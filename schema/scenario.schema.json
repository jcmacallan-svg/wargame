{
  "type": "object",
  "required": [
    "name",
    "overview",
    "level",
    "conflict_mode",
    "domains",
    "initial_blue_situation"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "overview": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "strategic",
        "operational",
        "tactical"
      ]
    },
    "conflict_mode": {
      "type": "string",
      "enum": [
        "hybrid",
        "peer",
        "grey_zone",
        "coin"
      ]
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "initial_blue_situation": {
      "type": "string"
    },
    "turn": {
      "type": "integer"
    },
    "escalation_stage": {
      "type": "integer"
    }
  }
}